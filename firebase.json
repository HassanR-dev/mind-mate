{
  "functions": {
    "source": "functions"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "frontend",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/*.exe",
      "**/*.EXE",
      "**/*.log",
      "**/Datasets/**",
      "**/functions/**",
      "**/Mind Mate - User Flow Chart — Eraser*",
      "**/state diagram mindmate.png"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/",
        "destination": "/login.html"
      }
    ]
  }
}
