{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "tasks":    { ".read": false, ".write": false },
    "gpas":     { ".read": false, ".write": false },
    "journals": { ".read": false, ".write": false }
  }
}
